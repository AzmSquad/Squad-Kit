---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[var(--color-border)] py-10">
  <div class="container-page flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] font-mono text-[13px] font-bold text-[var(--color-accent)]">
        sk
      </span>
      <div>
        <div class="text-sm font-medium">squad-kit</div>
        <div class="text-xs text-[var(--color-text-dim)]">MIT · © {year} Momen Yasser</div>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-[var(--color-text-muted)]">
      <a href="/docs/getting-started" class="hover:text-[var(--color-text)] transition-colors">Docs</a>
      <a href="/docs/philosophy" class="hover:text-[var(--color-text)] transition-colors">Philosophy</a>
      <a href="/docs/vs-spec-kit" class="hover:text-[var(--color-text)] transition-colors">vs Spec-Kit</a>
      <a href="https://www.npmjs.com/package/squad-kit" target="_blank" rel="noopener" class="hover:text-[var(--color-text)] transition-colors">npm</a>
      <a href="https://github.com/AzmSquad/Squad-Kit" target="_blank" rel="noopener" class="hover:text-[var(--color-text)] transition-colors">GitHub</a>
      <a href="https://github.com/AzmSquad/Squad-Kit/issues" target="_blank" rel="noopener" class="hover:text-[var(--color-text)] transition-colors">Issues</a>
    </div>
  </div>
</footer>
